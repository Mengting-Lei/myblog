---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { Image } from "astro:assets";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags, pubDatetime, ...props } = data;

// Use ogImage as cover image, fallback to null
const coverImage = data.ogImage;
---

<li class="group overflow-hidden rounded-2xl bg-white shadow-sm transition-shadow hover:shadow-md dark:bg-[#1a2e28]">
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class="block"
  >
    {/* Cover Image */}
    {coverImage ? (
      <div class="aspect-video overflow-hidden rounded-t-2xl bg-muted">
        <Image
          src={coverImage}
          alt={title}
          width={640}
          height={360}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    ) : (
      <div class="flex aspect-video items-center justify-center rounded-t-2xl bg-gradient-to-br from-accent/10 to-accent/5 text-accent/40 dark:from-accent/5 dark:to-accent/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>
    )}

    {/* Card Body */}
    <div class="p-5">
      {/* Tags */}
      {tags && tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {tags.slice(0, 3).map((tag) => (
            <span class="inline-block rounded-full bg-accent/10 px-3 py-0.5 text-xs font-medium text-accent dark:bg-accent/20">
              {tag}
            </span>
          ))}
        </div>
      )}

      {/* Title */}
      <Heading
        transition:name={`post-${id}`}
        class:list={[
          "mb-2 text-lg font-semibold leading-snug text-foreground line-clamp-2",
          "text-accent decoration-dashed underline-offset-4 group-hover:underline",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        {title}
      </Heading>

      {/* Description */}
      {description && (
        <p class="mb-3 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
          {description}
        </p>
      )}

      {/* Date */}
      <div class="mt-auto flex items-center gap-1 text-xs text-muted-foreground">
        <Datetime {...props} />
      </div>
    </div>
  </a>
</li>
