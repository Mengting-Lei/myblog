---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout
  title={`首页 | ${config.site.title}`}
  description="我是梦婷，品牌邮件营销增长顾问。在这里记录邮件营销、自由职业和个人成长，也提供相关咨询与服务。"
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-8">
      <h1 class="my-4 text-4xl font-bold sm:my-6 sm:text-5xl">
        你好，我是<span class="text-accent">梦婷</span> 👋
      </h1>

      <p class="text-lg leading-relaxed">
        品牌邮件营销增长顾问。
      </p>
      <p class="mt-2 leading-relaxed text-muted-foreground">
        我在这里记录邮件营销、自由职业和个人成长，也提供相关咨询与服务。
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <LinkButton
          href={getRelativeLocaleUrl(locale, "posts")}
          class="bg-accent text-accent-foreground hover:opacity-90 rounded-full px-6 py-2 font-medium transition-opacity"
        >
          查看文章
        </LinkButton>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "service")}
          class="border-border hover:border-accent hover:text-accent rounded-full border px-6 py-2 font-medium transition-colors"
        >
          了解服务
        </LinkButton>
      </div>

      {
        socials.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap text-sm text-muted-foreground sm:mb-0">
              找到我：
            </div>
            {/* 公众号：点击复制名称（放在小红书前面） */}
            <button
              id="wechat-copy-btn"
              type="button"
              class="me-1 inline-flex cursor-pointer items-center justify-center rounded-md p-2 transition-all hover:bg-accent/10 sm:p-1"
              title="点击复制公众号名称「雷梦婷」"
            >
              <img
                src="/wechat-mp-logo.png"
                alt="微信公众号"
                width="24"
                height="24"
                class="inline-block size-6 rounded-md opacity-90 sm:size-5"
              />
            </button>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="mb-8 text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul class="flex flex-col gap-5">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="mb-8 text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul class="flex flex-col gap-5">
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    // 公众号名称复制
    const copyBtn = document.getElementById("wechat-copy-btn");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText("雷梦婷");
          const originalTitle = copyBtn.getAttribute("title");
          copyBtn.setAttribute("title", "已复制「雷梦婷」！");
          (copyBtn as HTMLElement).style.filter = "brightness(0) saturate(100%) invert(69%) sepia(94%) saturate(2476%) hue-rotate(131deg) brightness(97%) contrast(101%)";
          setTimeout(() => {
            copyBtn.setAttribute("title", originalTitle || "");
            (copyBtn as HTMLElement).style.filter = "";
          }, 1500);
        } catch (e) {
          console.error("复制失败:", e);
        }
      });
    }
  });
</script>
